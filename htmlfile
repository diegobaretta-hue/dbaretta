<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soccer Hub</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0b0f1a;
      color: white;
    }

    header {
      background: #111827;
      padding: 20px;
      text-align: center;
    }

    header h1 {
      color: #22c55e;
    }

    nav {
      display: flex;
      justify-content: center;
      background: #1f2937;
    }

    nav a {
      color: white;
      padding: 15px;
      text-decoration: none;
    }

    nav a:hover {
      background: #22c55e;
      color: black;
    }

    section {
      padding: 30px;
    }

    h2 {
      margin-bottom: 15px;
      color: #22c55e;
    }

    .cards {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
    }

    .card {
      background: #1f2937;
      padding: 20px;
      border-radius: 10px;
      flex: 1;
      min-width: 200px;
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    th, td {
      border: 1px solid #374151;
      padding: 10px;
      text-align: center;
    }

    th {
      background: #22c55e;
      color: black;
    }

    footer {
      text-align: center;
      padding: 15px;
      background: #111827;
      margin-top: 20px;
    }

    /* Mobile */
    @media (max-width: 768px) {
      .cards {
        flex-direction: column;
      }
    }
  </style>
</head>

<body>

  <header>
    <h1>⚽ Soccer Hub</h1>
    <p>Teams, Players & Stats</p>
  </header>

  <nav>
    <a href="#teams">Teams</a>
    <a href="#players">Players</a>
    <a href="#stats">Stats</a>
  </nav>

  <!-- Teams -->
  <section id="teams">
    <h2>Top Teams</h2>
    <div class="cards">
      <div class="card">
        <h3>Real Madrid</h3>
        <p>La Liga Giants</p>
      </div>
      <div class="card">
        <h3>Manchester City</h3>
        <p>Premier League Champions</p>
      </div>
      <div class="card">
        <h3>Barcelona</h3>
        <p>Spanish Powerhouse</p>
      </div>
    </div>
  </section>

  <!-- Players -->
  <section id="players">
    <h2>Star Players</h2>
    <div class="cards">
      <div class="card">
        <h3>Lionel Messi</h3>
        <p>Forward</p>
      </div>
      <div class="card">
        <h3>Cristiano Ronaldo</h3>
        <p>Forward</p>
      </div>
      <div class="card">
        <h3>Kylian Mbappé</h3>
        <p>Forward</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="stats">
    <h2>Player Stats</h2>

    <table>
      <tr>
        <th>Player</th>
        <th>Goals</th>
        <th>Assists</th>
        <th>Matches</th>
      </tr>
      <tr>
        <td>Messi</td>
        <td>30</td>
        <td>12</td>
        <td>35</td>
      </tr>
      <tr>
        <td>Ronaldo</td>
        <td>28</td>
        <td>8</td>
        <td>34</td>
      </tr>
      <tr>
        <td>Mbappé</td>
        <td>32</td>
        <td>10</td>
        <td>33</td>
      </tr>
    </table>
  </section>

  <footer>
    <p>© 2026 Soccer Hub Project</p>
  </footer>

</body>
</html>
